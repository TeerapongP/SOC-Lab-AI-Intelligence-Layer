# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_LLM_OUTPUT_TOPIC=pa5220.llm_output
KAFKA_LLM_DLQ_TOPIC=pa5220.llm_output.dlq
KAFKA_DISPATCHER_GROUP=alert-dispatcher
KAFKA_AUTO_OFFSET=latest
KAFKA_CONNECT_RETRIES=30
KAFKA_DOCKER_BOOTSTRAP=kafka-broker:29092

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_GRAFANA_BASE_URL=http://localhost:3000

# RabbitMQ - reused from OpenCTI stack
RABBITMQ_URL=amqp://opencti:<password>@localhost:5672/
RABBITMQ_DOCKER_URL=amqp://opencti:<password>@host.docker.internal:5672/
RABBITMQ_EXCHANGE=soc.alerts

# InfluxDB - observability stack
INFLUX_URL=http://localhost:8086
INFLUX_DOCKER_URL=http://host.docker.internal:8086
INFLUX_TOKEN=
INFLUX_ORG=soc
INFLUX_BUCKET=alerts

# Elasticsearch - OpenCTI stack
ELASTIC_URL=http://localhost:9200
ELASTIC_DOCKER_URL=http://host.docker.internal:9200
ELASTIC_API_KEY=
ELASTIC_READER_API_KEY=
ELASTIC_ALERT_INDEX=soc-alerts

# Grafana
GRAFANA_URL=http://localhost:3000
